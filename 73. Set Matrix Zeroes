class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {
        int row = matrix.size();
        int col = matrix[0].size();
        vector<int> rows, cols;
        int k = 0;
        for (int i = 0; i < row; i++) {
            for (int j = 0; j < col; j++) {
                if (matrix[i][j] == 0) {
                    rows.push_back(i);
                    cols.push_back(j);
                }
            }
        }
        for (int i = 0; i < rows.size(); i++) {
            int r = rows[i];
            int c = cols[i];
            for (int i = 0; i < row; i++) {
                matrix[i][c] = 0;
            }
            for (int j = 0; j < col; j++) {
                matrix[r][j] = 0;
            }
        }
    }
};
