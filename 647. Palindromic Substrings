class Solution {
public:
int solve(string & s, int i , int j){
    if(i> j) return 1;
    if(i==j) return 1;
    if(s[i]!=s[j]) return 0;
    return solve(s,i+1,j-1);

}
    int countSubstrings(string s) {
        int count=0, n = s.size();
        for(int i =0;i<n;i++){
            for(int j=i;j<n;j++)
               count += solve(s,i,j);
        }
return count;
    }
};
