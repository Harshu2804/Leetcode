class Solution {
public:
    vector<int> concatWithReverse(vector<int>& nums) {
        vector<int>arr;
        for(int i =0;i<nums.size();i++){
            arr.push_back(nums[i]);
        }
        reverse(nums.begin(),nums.end());
        for(int i =0;i<nums.size();i++){
            arr.push_back(nums[i]);
        }
        return arr;
    }
};
