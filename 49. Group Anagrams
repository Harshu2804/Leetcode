class Solution {
public:
    vector<vector<string>> groupAnagrams(vector<string>& strs) {
        unordered_map<string,vector<string>>hash;
        for(string word :strs){
            string s = word;
            sort(s.begin(),s.end());
            hash[s].push_back(word);
        }
        vector<vector<string>>result;
        for(auto &i : hash){
            result.push_back(i.second);
        }
        return result;
    }
};
