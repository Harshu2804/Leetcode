class Solution {
public:
    int findMin(vector<int>& nums) {
        for (int i = 1; i < nums.size(); i++) {
            if (nums[i] >= nums[i - 1] && nums[i]) {
                continue;
            }
            if (i < nums.size() - 2) {
                if (nums[i] < nums[i - 1] && nums[i] >= nums[i + 1] ||
                    nums[i] < nums[i - 1] && nums[i] < nums[i + 1]) {
                    return nums[i];
                }
            } else {
                if (nums[i] < nums[i - 1] && nums[i] < nums[0]) {
                    return nums[i];
                }
            }
        }
        return nums[0];
    }
};
