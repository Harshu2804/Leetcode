class Solution {
public:
    int numberOfSubstrings(string s) {
        int i = 0, j = 0;
        int a = 0, b = 0, c = 0;
        long long ans = 0;
        int n = s.size();
        if (n < 3)
            return 0;
        while (j < s.size()) {
            if (s[j] == 'a')
                a++;
            else if (s[j] == 'b')
                b++;
            else if (s[j] == 'c')
                c++;
            while (a >0 && b >0 && c >0) {
                ans += n - j ;
                if (s[i] == 'a')
                    a--;
                else if (s[i] == 'b')
                    b--;
                else if (s[i] == 'c')
                    c--;
                i++;
            }
            j++;
        }
        return ans;
    }
};
