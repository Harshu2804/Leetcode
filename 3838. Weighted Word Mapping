class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string result="";
        for(string word : words){
        int sum=0;
            for(int i =0;i<word.size();i++){
            sum += (weights[word[i]-'a']) ;
            }
            sum %= 26;
            char ch = 'z'-sum;
            result.push_back(ch);
        }
        return result;
    }
};
