class Solution {
public:
    int minimumCost(vector<int>& cost) {
        int n = cost.size(),i;
        sort(cost.begin(), cost.end());
        int sum=0;
        if(n<2) return cost[0];
        for (i = n - 1; i > 0; i=i-3) {
            int purchase = cost[i] + cost[i - 1];
            sum += purchase;
           
        }
       if(i==0) sum += cost[0];
        return sum;
    }
};
